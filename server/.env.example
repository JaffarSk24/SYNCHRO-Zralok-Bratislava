# Copy to /etc/synchrozralok/.env on the server (chmod 600, owner www-data).
# NEVER commit the real file with values.

# Google reCAPTCHA v2 (works for synchrozralok.com and synchrozralok.sk)
RECAPTCHA_SITE_KEY=PASTE_PUBLIC_SITE_KEY
RECAPTCHA_SECRET=PASTE_SECRET_KEY

# Mailgun (EU region; sending domain mg.synchrozralok.sk, DNS on synchrozralok.sk)
MAILGUN_API_KEY=PASTE_MAILGUN_SENDING_API_KEY
MAILGUN_DOMAIN=mg.synchrozralok.sk
MAILGUN_BASE=https://api.eu.mailgun.net/v3

# Addresses (unified sender; CLUB_EMAIL is where applications arrive)
FROM_EMAIL="SYNCHRO Žralok <ahoj@synchrozralok.sk>"
CLUB_EMAIL=9035038@gmail.com
