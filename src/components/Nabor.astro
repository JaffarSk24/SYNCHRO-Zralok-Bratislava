---
import club from "../content/club.json";

const subject = "Prihláška do klubu Synchro Žralok Bratislava";
const body = `Dobrý deň,
mám záujem o prihlásenie dieťaťa do klubu Synchro Žralok Bratislava.

Meno dieťaťa:
Dátum narodenia:

Meno rodiča:
Telefónne číslo:`;
const mailto = `mailto:${club.email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
---

<section id="nabor" class="relative bg-deep py-20 md:py-28 overflow-hidden">
  <div class="glow-clip" aria-hidden="true">
    <div class="glow" style="width:520px;height:520px;background:#22d3ee;top:-180px;left:-120px;opacity:0.22"></div>
  </div>
  <div class="container-x relative">
    <div class="card p-8 md:p-12 max-w-3xl mx-auto text-center" data-reveal>
      <p class="eyebrow justify-center mb-4"><span class="w-6 hairline"></span> Nábor <span class="w-6 hairline"></span></p>
      <h2 class="text-3xl md:text-5xl font-bold leading-tight">Staň sa akvabelkou!</h2>

      <p class="mt-5 text-muted text-lg leading-relaxed">
        Miluješ vodu, pohyb a zábavu? Príď objaviť čaro synchronizovaného plávania, kde sa spája
        plávanie, tanec, gymnastika a hudba. Nájdeš u nás nové kamarátky, zažiješ množstvo
        nezabudnuteľných zážitkov a naučíš sa zručnosti, ktoré ti zostanú na celý život.
      </p>
      <p class="mt-4 text-muted text-lg leading-relaxed">
        Pridaj sa k úspešnému tímu Synchro Žralok a zaži s nami radosť z pohybu vo vode! 🦈💙
      </p>

      <div class="mt-8 flex justify-center">
        <a href={mailto} class="btn btn-primary">
          <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Zaslať prihlášku
        </a>
      </div>
    </div>
  </div>
</section>
