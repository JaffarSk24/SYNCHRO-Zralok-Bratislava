---
import { medals, t } from "../i18n";
const order = ["U8", "U10", "U12", "U15"] as const;
const groupMeta = t.titles.groupMeta;
const ct = medals.clubTotal;
type Tally = { gold: number; silver: number; bronze: number; total: number };
const groups = medals.groups as Record<string, Tally>;

const medalRows = (g: Tally) => [
  { kind: "gold", label: t.medalWords.gold, n: g.gold, cls: "text-gold", grad: "linear-gradient(135deg,#fde68a,#d4a017)" },
  { kind: "silver", label: t.medalWords.silver, n: g.silver, cls: "text-silver", grad: "linear-gradient(135deg,#f1f5f9,#94a3b8)" },
  { kind: "bronze", label: t.medalWords.bronze, n: g.bronze, cls: "text-bronze", grad: "linear-gradient(135deg,#f0b27a,#b06a2c)" },
];
---

<section id="tituly" class="relative bg-abyss py-20 md:py-28">
  <div class="glow-clip" aria-hidden="true">
    <div class="glow" style="width:480px;height:480px;background:#0ea5e9;top:10%;right:-160px;opacity:0.22"></div>
  </div>
  <div class="container-x relative">
    <div class="max-w-2xl" data-reveal>
      <p class="eyebrow mb-4"><span class="w-6 hairline"></span> {t.titles.eyebrow}</p>
      <h2 class="text-3xl md:text-4xl font-bold leading-tight">{t.titles.h2}</h2>
      <p class="mt-4 text-muted text-lg">{t.titles.intro}</p>
    </div>

    <!-- club total banner -->
    <div class="mt-10 card p-6 md:p-7 flex flex-col sm:flex-row items-center gap-6 justify-between" data-reveal>
      <div>
        <div class="text-sm text-muted uppercase tracking-widest">{t.titles.clubTotal}</div>
        <div class="font-display font-bold text-4xl md:text-5xl mt-1">
          {ct.total} <span class="text-muted text-2xl md:text-3xl font-semibold">{t.titles.medals}</span>
        </div>
      </div>
      <div class="flex items-center gap-6 md:gap-9">
        {[["gold",ct.gold,"#d4a017"],["silver",ct.silver,"#94a3b8"],["bronze",ct.bronze,"#b06a2c"]].map(([k,n,c]) => (
          <div class="text-center">
            <div class="mx-auto w-11 h-11 rounded-full grid place-items-center font-bold text-abyss" style={`background:${k==="gold"?"linear-gradient(135deg,#fde68a,#d4a017)":k==="silver"?"linear-gradient(135deg,#f1f5f9,#94a3b8)":"linear-gradient(135deg,#f0b27a,#b06a2c)"}`}>{n}</div>
            <div class="text-xs text-muted mt-2 capitalize">{k==="gold"?t.medalWords.gold:k==="silver"?t.medalWords.silver:t.medalWords.bronze}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- group cards -->
    <div class="mt-6 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {order.map((key, index) => {
        const g = groups[key];
        return (
          <div class="card p-6 relative overflow-hidden group" data-reveal style={`animation-delay: ${index * 100}ms`}>
            <div class="absolute -top-8 -right-6 font-display font-bold text-[5.5rem] leading-none text-white/[0.04] select-none">{key}</div>
            <div class="relative">
              <div class="flex items-baseline gap-2">
                <span class="font-display font-bold text-2xl text-cyan">{key}</span>
                <span class="text-xs text-muted">{groupMeta[key].age}</span>
              </div>
              <div class="text-xs text-muted/80">{groupMeta[key].note}</div>

              <div class="mt-5 space-y-2.5">
                {medalRows(g).map((m) => (
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2.5">
                      <span class="w-6 h-6 rounded-full" style={`background:${m.grad}`}></span>
                      <span class="text-sm text-muted">{m.label}</span>
                    </div>
                    <span class={`font-display font-bold text-xl ${m.cls}`}>{m.n}</span>
                  </div>
                ))}
              </div>

              <div class="hairline my-4"></div>
              <div class="flex items-center justify-between">
                <span class="text-xs uppercase tracking-wider text-muted">{t.titles.total}</span>
                <span class="font-display font-bold text-lg">{g.total}</span>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <p class="mt-6 text-xs text-muted/70 max-w-2xl" data-reveal>
      {t.titles.note} {t.titles.levelIntro} {medals.levelBased.gold}× {t.medalWords.gold},
      {medals.levelBased.silver}× {t.medalWords.silver}, {medals.levelBased.bronze}× {t.medalWords.bronze}.
    </p>
  </div>
</section>
