---
import { gallery, sustredenia, club, t } from "../i18n";
const items = gallery.slice(0, 13);

// Strip Instagram hashtags (#…) and @mentions from captions — they're noise for
// readers and confuse language detectors (lots of English #tags on a SK page).
const cleanCaption = (s?: string) =>
  (s ?? "")
    .replace(/[#@][\p{L}\p{N}_.]+/gu, "")
    .replace(/\s+/g, " ")
    .trim();
---

<section id="galeria" class="relative bg-abyss py-20 md:py-28">
  <div class="container-x">
    <div class="flex flex-wrap items-end justify-between gap-4" data-reveal>
      <div class="max-w-2xl">
        <p class="eyebrow mb-4"><span class="w-6 hairline"></span> {t.gallery.eyebrow}</p>
        <h2 class="text-3xl md:text-4xl font-bold leading-tight">{t.gallery.h2}</h2>
      </div>
      <a href={club.instagram} target="_blank" rel="noopener" class="btn btn-ghost !py-2.5 !px-5 text-sm">
        {t.gallery.more} →
      </a>
    </div>

    <!-- Deterministic masonry (built by JS for identical layout across browsers) -->
    <div id="gal-masonry" class="mt-9 flex flex-col gap-4">
      {items.map((g) => (
        <a
          href={g.permalink}
          target="_blank"
          rel="noopener"
          class="gal-item block rounded-2xl overflow-hidden border border-white/8 relative group"
          data-ratio={(g.h / g.w).toFixed(4)}
          data-reveal
        >
          <img
            src={g.src}
            alt={cleanCaption(g.caption) || club.name}
            width={g.w}
            height={g.h}
            loading="lazy"
            class="w-full h-auto object-cover transition-transform duration-500 group-hover:scale-105"
          />
          <span class="absolute inset-0 bg-gradient-to-t from-abyss/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></span>
          <span class="absolute bottom-3 left-3 right-3 text-xs text-ink/90 opacity-0 group-hover:opacity-100 transition-opacity line-clamp-2">{cleanCaption(g.caption)}</span>
        </a>
      ))}
    </div>

    <!-- Tábory a sústredenia — horizontal carousel -->
    <div class="mt-16" data-reveal>
      <div class="flex items-end justify-between gap-4 mb-6">
        <div>
          <p class="eyebrow mb-2"><span class="w-6 hairline"></span> {t.gallery.campsEyebrow}</p>
          <h3 class="text-2xl md:text-3xl font-bold leading-tight">{t.gallery.campsH}</h3>
        </div>
        <div class="hidden md:flex gap-2">
          <button class="sus-arrow" data-dir="-1" aria-label={t.gallery.prev}>
            <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <button class="sus-arrow" data-dir="1" aria-label={t.gallery.next}>
            <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      </div>

      <div id="sus-track" class="sus-track flex gap-4 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-2">
        {sustredenia.map((s) => (
          <a
            href={s.permalink}
            target="_blank"
            rel="noopener"
            class="group snap-start flex-none w-[220px] sm:w-[250px]"
          >
            <div class="relative aspect-[3/4] rounded-2xl overflow-hidden border border-white/8">
              <img src={s.src} alt={s.title} loading="lazy" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
              <div class="absolute inset-0" style="background:linear-gradient(to top, color-mix(in srgb,var(--color-abyss) 92%, transparent) 6%, transparent 55%)"></div>
              <div class="absolute bottom-0 inset-x-0 p-4">
                <div class="font-display font-semibold text-ink leading-snug">{s.flag ? `${s.flag} ` : ""}{s.title}</div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .sus-track { scrollbar-width: none; }
  .sus-track::-webkit-scrollbar { display: none; }
  .sus-arrow {
    width: 40px; height: 40px; border-radius: 999px;
    display: grid; place-items: center; color: var(--color-ink);
    border: 1px solid color-mix(in srgb, var(--color-cyan) 30%, transparent);
    transition: background .18s ease, transform .18s ease;
  }
  .sus-arrow:hover { background: color-mix(in srgb, var(--color-cyan) 12%, transparent); transform: translateY(-1px); }
</style>

<script>
  // --- carousel arrows ---
  const track = document.getElementById("sus-track");
  if (track) {
    document.querySelectorAll<HTMLButtonElement>(".sus-arrow").forEach((btn) => {
      btn.addEventListener("click", () => {
        const dir = Number(btn.dataset.dir) || 1;
        track.scrollBy({ left: dir * Math.round(track.clientWidth * 0.8), behavior: "smooth" });
      });
    });
  }

  // --- deterministic masonry (identical in every browser) ---
  const root = document.getElementById("gal-masonry");
  if (root) {
    const items = Array.from(root.querySelectorAll<HTMLElement>(".gal-item"));
    const ratios = items.map((it) => parseFloat(it.dataset.ratio || "1") + 0.06);
    let builtCols = 0;
    const colCount = () => (window.innerWidth >= 1024 ? 4 : window.innerWidth >= 768 ? 3 : 2);

    // optimal contiguous partition into `cols` columns (minimise tallest column,
    // keeps document order -> staggered look, balanced bottoms, deterministic)
    const partition = (cols: number): number[][] => {
      const n = ratios.length;
      const total = ratios.reduce((a, b) => a + b, 0);
      const maxItem = Math.max(...ratios);
      const fits = (cap: number) => {
        let used = 1, sum = 0;
        for (const r of ratios) {
          if (sum + r > cap) { used++; sum = r; } else sum += r;
        }
        return used <= cols;
      };
      let lo = maxItem, hi = total;
      for (let i = 0; i < 60 && hi - lo > 1e-4; i++) {
        const mid = (lo + hi) / 2;
        if (fits(mid)) hi = mid; else lo = mid;
      }
      const cap = hi + 1e-4;
      const groups: number[][] = [];
      let cur: number[] = [], sum = 0;
      for (let i = 0; i < n; i++) {
        if (cur.length && sum + ratios[i] > cap) {
          groups.push(cur); cur = []; sum = 0;
        }
        cur.push(i); sum += ratios[i];
      }
      if (cur.length) groups.push(cur);
      while (groups.length < cols) groups.push([]); // safety (rarely needed)
      return groups;
    };

    const build = () => {
      const cols = colCount();
      if (cols === builtCols) return; // ratio-based -> width-independent
      builtCols = cols;
      // inline styles (JS-created nodes don't get Astro's scoped-style attribute)
      root.style.display = "grid";
      root.style.gap = "1rem";
      root.style.alignItems = "start";
      root.style.gridTemplateColumns = `repeat(${cols}, minmax(0, 1fr))`;
      const groups = partition(cols);
      const colEls = groups.map((g) => {
        const c = document.createElement("div");
        c.style.display = "flex";
        c.style.flexDirection = "column";
        c.style.gap = "1rem";
        c.style.minWidth = "0";
        g.forEach((idx) => c.appendChild(items[idx]));
        return c;
      });
      root.replaceChildren(...colEls);
    };
    build();
    let t: number | undefined;
    window.addEventListener("resize", () => {
      window.clearTimeout(t);
      t = window.setTimeout(build, 150);
    });
  }
</script>
