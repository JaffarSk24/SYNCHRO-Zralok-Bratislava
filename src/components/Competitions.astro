---
import competitions from "../content/competitions.json";
const months = ["jan", "feb", "mar", "apr", "máj", "jún", "júl", "aug", "sep", "okt", "nov", "dec"];
const fmt = (d: string) => {
  const [y, m] = d.split("-").map(Number);
  return `${months[m - 1]} ${y}`;
};
const flag: Record<string, string> = { Slovensko: "🇸🇰", Maďarsko: "🇭🇺", Česko: "🇨🇿" };
---

<section id="sutaze" class="relative bg-deep py-20 md:py-28">
  <div class="container-x relative">
    <div class="max-w-2xl" data-reveal>
      <p class="eyebrow mb-4"><span class="w-6 hairline"></span> Súťaže</p>
      <h2 class="text-3xl md:text-4xl font-bold leading-tight">Výsledky z pretekov</h2>
      <p class="mt-4 text-muted text-lg">
        Najnovšie štarty našich žralokýň doma aj v zahraničí. Sezóna pokračuje – sledujte nás na Instagrame.
      </p>
    </div>

    <div class="mt-10 relative">
      <div class="absolute left-3 md:left-1/2 top-0 bottom-0 w-px bg-white/10 md:-translate-x-1/2" aria-hidden="true"></div>
      <ul class="space-y-4 md:space-y-0">
        {competitions.map((c, i) => (
          <li class="relative md:grid md:grid-cols-2 md:gap-8" data-reveal>
            <span class="absolute left-3 md:left-1/2 top-7 md:top-1/2 w-3 h-3 rounded-full bg-cyan -translate-x-1/2 md:-translate-y-1/2 ring-4 ring-deep"></span>
            <div class={`ml-9 md:ml-0 md:mb-8 ${i % 2 ? "md:col-start-2" : "md:pr-2"}`}>
              <div class="card p-5 hover:border-cyan/40 transition-colors">
                <div class="flex items-center justify-between gap-3">
                  <span class="text-xs font-semibold uppercase tracking-wider text-cyan">{fmt(c.date)}</span>
                  {c.location && <span class="text-sm text-muted">{flag[c.location] ?? ""} {c.location}</span>}
                </div>
                <h3 class="mt-2 font-display font-semibold text-lg leading-snug">{c.title}</h3>
                <div class="mt-3 flex items-center gap-4 text-sm">
                  {c.medals.gold > 0 && <span class="flex items-center gap-1.5"><span class="w-4 h-4 rounded-full" style="background:linear-gradient(135deg,#fde68a,#d4a017)"></span>{c.medals.gold}</span>}
                  {c.medals.silver > 0 && <span class="flex items-center gap-1.5"><span class="w-4 h-4 rounded-full" style="background:linear-gradient(135deg,#f1f5f9,#94a3b8)"></span>{c.medals.silver}</span>}
                  {c.medals.bronze > 0 && <span class="flex items-center gap-1.5"><span class="w-4 h-4 rounded-full" style="background:linear-gradient(135deg,#f0b27a,#b06a2c)"></span>{c.medals.bronze}</span>}
                  {c.permalink && <a href={c.permalink} target="_blank" rel="noopener" class="ml-auto text-muted hover:text-cyan transition-colors">Pozrieť →</a>}
                </div>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
