---
import { club, medals, t } from "../i18n";
import Logo from "./Logo.astro";
const ct = medals.clubTotal;
---

<section id="top" class="relative pt-[120px] pb-24 md:pt-[160px] md:pb-32">
  <!-- water glow — wrapped to prevent filter bleed across compositing layers -->
  <div class="glow-clip" aria-hidden="true">
    <div class="glow" style="width:520px;height:520px;background:#0ea5e9;top:-120px;left:-120px"></div>
    <div class="glow" style="width:460px;height:460px;background:#22d3ee;bottom:-160px;right:-100px;opacity:0.35"></div>
  </div>
  <div class="absolute inset-0 -z-10" style="background:radial-gradient(1200px 600px at 70% -10%, color-mix(in srgb, var(--color-pool) 80%, transparent), transparent 70%)"></div>

  <div class="container-x relative grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-6 items-center">
    <div data-reveal>
      <p class="eyebrow mb-5">
        <span class="w-6 hairline"></span> {club.city}
      </p>
      <h1 class="text-[2.7rem] sm:text-6xl lg:text-7xl font-bold leading-[0.95]">
        {t.hero.l1}<br />
        {t.hero.l2}<br />
        <span class="text-transparent bg-clip-text" style="background-image:linear-gradient(120deg,var(--color-cyan),var(--color-aqua))">{t.hero.l3}</span>
      </h1>
      <p class="mt-6 text-lg text-muted max-w-xl">{club.intro}</p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href="#kempy" class="btn btn-primary">{t.hero.ctaJoin}</a>
        <a href="#tituly" class="btn btn-ghost">{t.hero.ctaAch}</a>
      </div>

      <div class="mt-10 flex flex-wrap gap-x-8 gap-y-3 text-sm">
        <div class="flex items-baseline gap-2">
          <span class="font-display font-bold text-2xl text-gold">{ct.gold}</span>
          <span class="text-muted">{t.hero.gold}</span>
        </div>
        <div class="flex items-baseline gap-2">
          <span class="font-display font-bold text-2xl text-silver">{ct.silver}</span>
          <span class="text-muted">{t.hero.silver}</span>
        </div>
        <div class="flex items-baseline gap-2">
          <span class="font-display font-bold text-2xl text-bronze">{ct.bronze}</span>
          <span class="text-muted">{t.hero.bronze}</span>
        </div>
      </div>
    </div>

    <div class="relative flex justify-center lg:justify-end" data-reveal>
      <!-- centered glow circle + shark -->
      <div class="relative w-[78%] max-w-[420px] aspect-square flex items-center justify-center">
        <div class="absolute inset-0 rounded-full" style="background:radial-gradient(circle, color-mix(in srgb,var(--color-cyan) 32%, transparent), transparent 68%)"></div>
        <Logo class="relative w-[85%] h-[85%] text-ink animate-floaty drop-shadow-[0_20px_40px_rgba(0,0,0,0.5)]" />
      </div>
    </div>
  </div>

  <!-- wave divider -->
  <div class="absolute bottom-0 inset-x-0 leading-none text-deep" aria-hidden="true">
    <svg viewBox="0 0 1440 120" preserveAspectRatio="none" class="w-full h-[60px] md:h-[90px]">
      <path fill="currentColor" d="M0,64 C240,120 480,16 720,48 C960,80 1200,120 1440,72 L1440,120 L0,120 Z"></path>
    </svg>
  </div>
</section>
