---
// Highlight: U12 (mladšie žiačky) won GOLD in every discipline at
// Majstrovstvá Slovenska & Synchrostars 2026.
const disciplines = ["Povinné figúry", "Sólo", "Duo", "Tím", "Kombinovaná zostava"];
---

<section id="majsterky" class="relative bg-abyss pb-20 md:pb-28">
  <div class="container-x">
    <div class="champ-card relative overflow-hidden rounded-3xl p-8 md:p-12" data-reveal>
      <!-- soft gold glow -->
      <div class="champ-glow" aria-hidden="true"></div>

      <div class="relative grid md:grid-cols-[auto_1fr] gap-8 md:gap-10 items-center">
        <!-- 5 overlapping gold cups, first one full / on top -->
        <div class="cups" aria-hidden="true">
          <svg viewBox="0 0 96 50" role="img" aria-label="5 zlatých pohárov">
            <defs>
              <linearGradient id="goldcup" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#fef3c7"/>
                <stop offset="0.5" stop-color="#fbcf5b"/>
                <stop offset="1" stop-color="#c8920f"/>
              </linearGradient>
              <g id="cup">
                <path d="M4 3 h20 v4 c0 7 -4.4 12 -10 12 S4 14 4 7 z"/>
                <path d="M3.5 4.5 c-3.2 0 -4.8 2 -4.8 4.4 c0 2.4 1.7 4.1 4.4 4.1 l0 -2.6 c-1.2 0 -2 -.7 -2 -1.6 c0 -1 .9 -1.7 2.4 -1.7 z"/>
                <path d="M24.5 4.5 c3.2 0 4.8 2 4.8 4.4 c0 2.4 -1.7 4.1 -4.4 4.1 l0 -2.6 c1.2 0 2 -.7 2 -1.6 c0 -1 -.9 -1.7 -2.4 -1.7 z"/>
                <path d="M11.5 19 h5 v6 h-5 z"/>
                <path d="M6 25 h16 v3.2 h-16 z"/>
                <path d="M4 28 h20 v4 q0 1.4 -1.4 1.4 h-17.2 q-1.4 0 -1.4 -1.4 z"/>
              </g>
            </defs>
            <!-- drawn back→front so the FIRST (leftmost) cup sits on top and is fully visible -->
            <use href="#cup" x="56" fill="url(#goldcup)" stroke="#050f1a" stroke-width="0.9" opacity="0.8"/>
            <use href="#cup" x="42" fill="url(#goldcup)" stroke="#050f1a" stroke-width="0.9" opacity="0.86"/>
            <use href="#cup" x="28" fill="url(#goldcup)" stroke="#050f1a" stroke-width="0.9" opacity="0.92"/>
            <use href="#cup" x="14" fill="url(#goldcup)" stroke="#050f1a" stroke-width="0.9" opacity="0.96"/>
            <use href="#cup" x="0"  fill="url(#goldcup)" stroke="#050f1a" stroke-width="0.9"/>
          </svg>
        </div>

        <div>
          <p class="eyebrow mb-3" style="color:var(--color-gold)">
            <span class="w-6 hairline" style="background:linear-gradient(90deg,transparent,var(--color-gold),transparent)"></span>
            Majsterky Slovenska 2026
          </p>
          <h2 class="text-2xl md:text-4xl font-bold leading-tight">
            U12 – zlato vo <span class="champ-hl">všetkých disciplínach</span>
          </h2>
          <p class="mt-4 text-muted text-lg max-w-2xl">
            Obrovská gratulácia našim <strong class="text-ink">mladším žiačkam (U12)</strong> – na
            Majstrovstvách Slovenska &amp; Synchrostars 2026 vybojovali <strong class="text-ink">zlato
            v každej jednej disciplíne</strong>. Päť štartov, päť zlatých! 🥇
          </p>

          <div class="mt-6 flex flex-wrap gap-2.5">
            {disciplines.map((d) => (
              <span class="champ-chip">🥇 {d}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .champ-card{
    background:
      radial-gradient(120% 140% at 0% 0%, color-mix(in srgb, var(--color-gold) 12%, transparent), transparent 55%),
      linear-gradient(180deg, color-mix(in srgb, var(--color-pool) 92%, transparent), color-mix(in srgb, var(--color-deep) 94%, transparent));
    border:1px solid color-mix(in srgb, var(--color-gold) 30%, transparent);
  }
  .champ-glow{
    position:absolute; top:-40%; left:-10%; width:420px; height:420px; border-radius:999px;
    background:radial-gradient(circle, color-mix(in srgb, var(--color-gold) 26%, transparent), transparent 65%);
    filter:blur(70px); pointer-events:none;
  }
  .cups{ width:200px; max-width:48vw; filter:drop-shadow(0 10px 18px rgba(0,0,0,.45)); }
  .cups svg{ width:100%; height:auto; display:block; }
  .champ-hl{
    color:transparent; background-clip:text; -webkit-background-clip:text;
    background-image:linear-gradient(100deg, var(--color-gold), #ffe9a8);
  }
  .champ-chip{
    display:inline-flex; align-items:center; gap:.35rem;
    font-size:.85rem; font-weight:600; color:var(--color-ink);
    padding:.4rem .8rem; border-radius:999px;
    background:color-mix(in srgb, var(--color-gold) 12%, transparent);
    border:1px solid color-mix(in srgb, var(--color-gold) 30%, transparent);
  }
  @media (max-width:767px){
    .cups{ width:160px; margin-inline:auto; }
  }
</style>
