---
import { events, t } from "../i18n";
const c = events.camps;
---

<section id="kempy" class="relative bg-abyss py-20 md:py-28">
  <div class="glow-clip" aria-hidden="true">
    <div class="glow" style="width:520px;height:520px;background:#22d3ee;bottom:-180px;left:-120px;opacity:0.25"></div>
  </div>
  <div class="container-x relative grid lg:grid-cols-[0.95fr_1.05fr] gap-10 items-center">
    <div data-reveal>
      <p class="eyebrow mb-4"><span class="w-6 hairline"></span> {t.camps.eyebrow}</p>
      <h2 class="text-3xl md:text-5xl font-bold leading-[1.02]">{c.title}</h2>
      <p class="mt-5 text-muted text-lg leading-relaxed">{c.description}</p>

      <ul class="mt-7 grid sm:grid-cols-2 gap-3">
        {c.includes.map((i) => (
          <li class="flex items-start gap-2.5 text-sm">
            <span class="flex-none mt-0.5 text-cyan">
              <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <span class="text-muted">{i}</span>
          </li>
        ))}
      </ul>

      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a href={c.ctaUrl} target="_blank" rel="noopener" class="btn btn-primary">{c.ctaLabel}</a>
        <div class="leading-tight">
          <span class="font-display font-bold text-2xl">{c.price}</span>
          <span class="text-muted text-sm">{c.priceNote}</span>
        </div>
      </div>
    </div>

    <div class="card p-6 md:p-8" data-reveal>
      <div class="flex items-center justify-between text-sm text-muted">
        <span>{c.audience}</span>
        <span>{c.location}</span>
      </div>
      <div class="hairline my-5"></div>

      <h3 class="font-display font-semibold text-lg mb-4">{t.camps.datesH}</h3>
      <ul class="space-y-3">
        {c.sessions.map((s, i) => (
          <li class="flex items-center gap-4 p-4 rounded-xl bg-white/[0.03] border border-white/5 hover:border-cyan/30 transition-colors">
            <span class="flex-none grid place-items-center w-10 h-10 rounded-full font-display font-bold text-abyss" style="background:linear-gradient(135deg,var(--color-cyan),var(--color-wave))">{i + 1}</span>
            <div>
              <div class="font-semibold">{s.dates}</div>
              <div class="text-xs text-muted">{s.label} · {c.schedule}</div>
            </div>
          </li>
        ))}
      </ul>
      <p class="mt-5 text-xs text-muted/80">{t.camps.note}</p>
    </div>
  </div>
</section>
