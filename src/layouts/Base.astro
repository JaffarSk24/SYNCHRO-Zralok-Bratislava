---
import "../styles/global.css";
import { club, faq as faqData, t, SITE_URL, ALT_URL, OG_LOCALE, HTML_LANG, LOCALE } from "../i18n";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}
const {
  title = t.seo.title,
  description = t.seo.description,
  image = "/og-image.png",
} = Astro.props;

const siteUrl = SITE_URL;
const canonical = `${siteUrl}${Astro.url.pathname}`;
const ogImage = `${siteUrl}${image}`;
const inLanguage = LOCALE === "en" ? "en-GB" : "sk-SK";

// Schema.org JSON-LD
const schemaOrg = [
  // Primary: SportsOrganization (rich results, knowledge panel)
  {
    "@context": "https://schema.org",
    "@type": ["SportsOrganization", "LocalBusiness"],
    "@id": `${siteUrl}/#organization`,
    name: club.name,
    alternateName: club.shortName,
    url: siteUrl,
    logo: `${siteUrl}/logo-zralok.svg`,
    image: ogImage,
    description: club.intro,
    sport: "Synchronized Swimming",
    foundingDate: "2004",
    areaServed: {
      "@type": "City",
      name: "Bratislava",
      "@id": "https://www.wikidata.org/wiki/Q1780",
    },
    address: {
      "@type": "PostalAddress",
      addressLocality: "Bratislava",
      addressRegion: "Bratislavský kraj",
      addressCountry: "SK",
    },
    sameAs: [
      club.instagram,
      "https://www.instagram.com/synchro.zralok.bratislava/",
    ],
    numberOfEmployees: { "@type": "QuantitativeValue", value: 4 },
    knowsAbout: [
      "Synchronized swimming",
      "Artistic swimming",
      "Akvabelky",
      "Synchronizované plávanie",
    ],
  },
  // WebSite — enables Sitelinks Searchbox
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${siteUrl}/#website`,
    url: siteUrl,
    name: club.name,
    inLanguage,
    publisher: { "@id": `${siteUrl}/#organization` },
  },
  // BreadcrumbList — helps sitelinks
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "O klube", item: `${siteUrl}/#o-klube` },
      { "@type": "ListItem", position: 2, name: "Naše tituly", item: `${siteUrl}/#tituly` },
      { "@type": "ListItem", position: 3, name: "Letné kempy", item: `${siteUrl}/#kempy` },
      { "@type": "ListItem", position: 4, name: "Galéria", item: `${siteUrl}/#galeria` },
      { "@type": "ListItem", position: 5, name: "Kontakt", item: `${siteUrl}/#kontakt` },
    ],
  },
  // FAQPage — gives Google rich results / expanded snippets
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqData.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.a,
      },
    })),
  },
  // Event: upcoming summer camp
  {
    "@context": "https://schema.org",
    "@type": "Event",
    name: "Letný kemp Akvabelky 2026",
    startDate: "2026-07-13",
    endDate: "2026-08-08",
    eventStatus: "https://schema.org/EventScheduled",
    eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
    location: {
      "@type": "Place",
      name: "Plavecká Akadémia Devínska",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Bratislava – Devínska Nová Ves",
        addressCountry: "SK",
      },
    },
    organizer: { "@id": `${siteUrl}/#organization` },
    offers: {
      "@type": "Offer",
      price: "189",
      priceCurrency: "EUR",
      availability: "https://schema.org/InStock",
      url: "https://plaveckaakademia.sk/kurzy/pre-deti/camp-akvabelky",
    },
    description: t.seo.campDesc,
  },
];
---

<!doctype html>
<html lang={HTML_LANG}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <!-- hreflang: SK on .sk, EN on .com, both point to the same path -->
    <link rel="alternate" hreflang="sk" href={`https://synchrozralok.sk${Astro.url.pathname}`} />
    <link rel="alternate" hreflang="en" href={`https://synchrozralok.com${Astro.url.pathname}`} />
    <link rel="alternate" hreflang="x-default" href={`https://synchrozralok.com${Astro.url.pathname}`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#050f1a" />

    <!-- SEO -->
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <!-- 2026 SEO: long-tail + local + conversational + voice-search queries -->
    <meta name="keywords" content={t.seo.keywords} />
    <meta name="author" content="SYNCHRO Žralok Bratislava" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={club.name} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t.seo.ogAlt} />
    <meta property="og:locale" content={OG_LOCALE} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org JSON-LD -->
    {schemaOrg.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <slot />

    <script>
      // reveal-on-scroll
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              (e.target as HTMLElement).classList.add("in");
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll("[data-reveal]").forEach((el, i) => {
        const htmlEl = el as HTMLElement;
        if (!htmlEl.style.animationDelay) {
          htmlEl.style.animationDelay = `${(i % 6) * 80}ms`;
        }
        io.observe(el);
      });
    </script>
  </body>
</html>

